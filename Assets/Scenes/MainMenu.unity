    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\uC120\uBC30\uAC00 \uC900 \uC885\uC774\uC5D0\uB294 \uB2E4\uC591\uD55C
    \uC815\uBCF4\uB4E4\uC774 \uB9CE\uC558\uB2E4.\r\n\uADF8\uB3D9\uC548 \uD0C8\uCD9C\uD558\uAE30
    \uC704\uD574 \uC5C4\uCCAD\uB09C \uB178\uB825\uC744 \uD55C \uB4EF\uD588\uB2E4.\r\n\r\n\u2018\uB9F5\uC740
    6\uAC1C\uC758 \uAC15\uC758\uC2E4, \uC8FC\uBC29, \uC870\uB9AC\uC2E4, \uC815\uC6D0,
    \uD654\uC7A5\uC2E4,\n \uB9E4\uC810, \uC2A4\uD3F0\uC9C0, \uC7A0\uAE34\uC785\uAD6C\uB85C
    \uAD6C\uC131\uB418\uC5B4 \uC788\uC744 \uC815\uB3C4\uB85C\n \uB113\uAE30 \uB54C\uBB38\uC5D0
    \uC8FC\uC758\uD574\uC57C\uD55C\uB2E4.\u2019\r\n\r\n\uBBF8\uC158\uACFC \uB9C8\uCC2C\uAC00\uC9C0\uB85C
    \uC67C\uCABD \uC704\uC758 \uC885\uC774\uB97C \uB204\uB974\uBA74\n\uB9F5\uC774
    \uD568\uAED8 \uBCF4\uC774\uB2C8 \uB9F5\uC744 \uD30C\uC545\uD558\uBA70 \uB2E4\uB2C8\uC790!\r\n"
