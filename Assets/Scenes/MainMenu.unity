    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\uC804\uC124\uB85C\uB9CC \uC804\uD574\uB0B4\uB824\uC624\uB358 \uC120\uBC30\uB97C
    \uD589\uC6B4\uCC98\uB7FC \uB9CC\uB098\uAC8C \uB418\uC5C8\uB2E4.\r\n\uD559\uAD50\uB97C
    18\uB144\uB3D9\uC548 \uB2E4\uB154\uB2E4\uB294 \uC804\uC124\uC774 \uC0AC\uC2E4\uC774\uC5C8\uB294\uC9C0,\n\uC120\uBC30\uB294
    \uC6B0\uB9AC\uC5D0\uAC8C \uB3C4\uC6C0\uC744 \uC8FC\uC168\uB2E4.\r\n\n\u201C\uAD50\uC218\uB2D8\uAED8
    \uC7A1\uD788\uBA74 \uB098\uC758 \uAF34\uC744 \uBA74\uD560 \uC218 \uC5C6\uC744\uAC70\uC57C.\n\uC9C0\uAE08
    \uB0B4\uAC00 \uC8FC\uB294 \uC885\uC774\uC5D0 \uC801\uD78C \uAC83\uB4E4\uB9CC
