--- !u!114 &640732440
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 640732438}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 2598866432e772640bec1ddc64077784, type: 3}
    m_FontSize: 27
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 1
    m_MaxSize: 132
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\u2018\uC870\uAD50\uC778 \uB300\uD559\uC6D0\uC0DD\uB3C4 \uC870\uC2EC\uD574\uC57C
    \uD55C\uB2E4. \n\uAD50\uC218\uB2D8\uC774 \uC900 \uACFC\uC81C\uB97C \uD559\uC0DD\uB4E4\uC5D0\uAC8C
    \uADF8\uB300\uB85C \uC8FC\uAE30 \uB54C\uBB38\uC774\uB2E4.\n\uD558\uC9C0\uB9CC
    \uB300\uD559\uC6D0\uC0DD\uC778\uB9CC\uD07C \uBAB8\uC774 \uACE0\uB418\uC11C \uADF8\uB7F0\uC9C0,\n\uACFC\uC81C\uAC00
    2\uAC1C\uB9CC \uC313\uC5EC\uB3C4 \uC4F0\uB7EC\uC838\uBC84\uB9B0\uB2E4.\u2019\r\n\r\n\uADF8\uB3D9\uC548
    \uBBFF\uC5C8\uB358 \uC870\uAD50\uB2D8\uB4E4\uAE4C\uC9C0 \uC774\uB807\uAC8C \uBCC0\uD55C\uAC8C
    \uBBFF\uAE30\uC9C0 \uC54A\uC558\uB2E4.\r\n\uC544\uC9C1 \uB2E4 \uC548 \uC77D\uC5B4\uC11C
    \uADF8\uB7F0\uC9C0,\n \uC885\uC774 \uC544\uB798\uC5D0 \uB610 \uBA54\uC2DC\uC9C0\uAC00
    \uB0A8\uACA8\uC838 \uC788\uC5B4 \uC77D\uC5B4\uBCF4\uC558\uB2E4.\r\n\r\n\u2018ps.
    \uB300\uD559\uC6D0\uC0DD \uADF8 \uCE5C\uAD6C\uB3C4 \uC0AC\uC2E4 \uC6D0\uCE58
    \uC54A\uC558\uC744 \uC218\uB3C4 \uC788\uC73C\uB2C8,\n \uB2E4\uC2DC \uD559\uC0DD\uC73C\uB85C
    \uB3CC\uC544\uC624\uACE0\uC790 \uD560 \uB54C\uB294 \uB2E4\uC2DC \uBC1B\uC544\uC8FC\uB3C4\uB85D
    \uD558\uC790.\u2019\r\n\r\n\uC544\uBB34\uB798\uB3C4 \uB300\uD559\uC6D0\uC0DD\uBD84\uB4E4\uC740
    \uC6B0\uB9AC\uC640 \uAC19\uC740 \uD559\uC0DD\uC774\uB098,\n\uAD50\uC218\uB2D8\uC73C\uB85C
    \uBCC0\uD560 \uC218\uB3C4 \uC788\uB098\uBCF4\uB2E4\u2026 \uC870\uC2EC\uD558\uC790!\u2019\r\n"
