  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 2598866432e772640bec1ddc64077784, type: 3}
    m_FontSize: 30
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 1
    m_MaxSize: 132
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\uB2E4\uB978 \uB300\uD559\uC0DD\uB4E4\uACFC \uB9C8\uCC2C\uAC00\uC9C0\uB85C,
    \uC5EC\uB290 \uB54C\uC640 \uAC19\uC774\n\uC6B0\uB9AC\uB4E4\uC740 \uD3C9\uBC94\uD558\uAC8C
    \uD559\uAD50\uB97C \uB2E4\uB2C8\uACE0 \uC788\uC5C8\uB2E4.\n\uADF8\uB7EC\uB358
    \uC5B4\uB290 \uB0A0, \n\uC6B0\uB9AC\uB4E4\uC758 \uD578\uB4DC\uD3F0\uC5D0\uB294
    \uD55C \uD1B5\uC758 \uBB38\uC790\uAC00 \uC640\uC788\uC5C8\uB2E4.\r\n\n\u201C\uD559\uC0DD\u2026
    \uB300\uD559\uC6D0 \uC640\uC11C \uB098\uC640 \uD568\uAED8 \uB354 \uC5F0\uAD6C\uD574\uBCFC
    \uC0DD\uAC01\uC788\uB098?\u201D\r\n\n\uADF8\uB807\uB2E4\u2026 \uBB34\uC2DC\uBB34\uC2DC\uD55C
    \uADF8 \uACF3\u2026 \n\uB300\uD559\uC6D0\uC73C\uB85C \uAF2C\uC2DC\uB294 \uBB38\uC790\uC600\uB2E4.\r\n\uC6B0\uB9AC\uB294
    \uB450\uB824\uC6C0\uC5D0 \uB5A8\uBA70 \uAC74\uBB3C\uC744 \uBC97\uC5B4\uB098\uB824
    \uD588\uC9C0\uB9CC,\n\uC774\uBBF8 \uAC74\uBB3C\uC740 \uBAA8\uB450 \uC7A0\uAE34
    \uB4A4\uC600\uB2E4.\n"
